---
// src/components/astro/About.astro
// Alberto Murillo bio — first person, Wentzville community connection (CONT-04)
// Photo: CSS placeholder until Alberto provides headshot (placeholder avoids build error)
// H2 section heading (SEO-04)
---
<section
  id="about"
  class="py-16 sm:py-20 px-4 bg-white dark:bg-dark-bg"
  aria-labelledby="about-heading"
>
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Photo column -->
      <div class="flex justify-center md:justify-start" data-animate>
        <!--
          PLACEHOLDER: Replace this div with an <Image> component once Alberto provides headshot.
          Import: import { Image } from 'astro:assets'; import albertoPhoto from '../../assets/images/alberto-murillo.jpg';
          Element: <Image src={albertoPhoto} alt="Alberto Murillo, owner of Redbird Lawn Service in Wentzville, MO" width={400} height={480} loading="lazy" class="rounded-2xl object-cover shadow-xl" />
        -->
        <div
          class="w-64 h-80 rounded-2xl bg-forest-green flex flex-col items-center justify-center text-white shadow-xl"
          role="img"
          aria-label="Alberto Murillo, owner of Redbird Lawn Service"
        >
          <span class="text-6xl font-bold font-heading mb-2">AM</span>
          <span class="text-light-green text-sm font-medium">Photo Coming Soon</span>
        </div>
      </div>

      <!-- Bio column -->
      <div data-animate data-animate-delay="200">
        <h2
          id="about-heading"
          class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-6"
        >
          About Alberto
        </h2>
        <div class="space-y-4 text-gray-600 dark:text-gray-300 leading-relaxed">
          <p>
            I started Redbird Lawn Care because I got tired of seeing my neighbors settle for crews
            that showed up late, did a rushed job, and were impossible to reach. Wentzville deserves better than that.
          </p>
          <p>
            I grew up here. My kids go to school here. When I pull up to your house, I'm not just doing a job — I'm taking
            care of a neighbor's yard.
          </p>
          <p>
            Every time I show up, you get mowed edges, clean curbs, and a crew that treats your property like their own.
            No mystery chemicals. No shortcuts. Just reliable work from someone who lives right here in Wentzville.
          </p>
        </div>

        <!-- Trust signal row -->
        <div class="flex flex-wrap gap-4 mt-8">
          <div class="flex items-center gap-2 text-sm font-medium text-forest-green dark:text-light-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            Fully Insured
          </div>
          <div class="flex items-center gap-2 text-sm font-medium text-forest-green dark:text-light-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
            5-Star Rated on Google
          </div>
          <div class="flex items-center gap-2 text-sm font-medium text-forest-green dark:text-light-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Wentzville Local
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
