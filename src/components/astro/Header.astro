---
// src/components/astro/Header.astro
// Sticky header — visible at all times while scrolling (CONV-05)
// Click-to-call phone link always visible on mobile (CONV-02)
// NAP data ONLY from constants.ts — never hardcoded
import { NAP } from '../../lib/constants';
---
<header class="sticky top-0 z-50 bg-white dark:bg-dark-bg shadow-sm border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Brand name -->
    <a href="/" class="font-heading font-bold text-lg text-forest-green dark:text-light-green hover:text-mid-green transition-colors">
      {NAP.name}
    </a>

    <!-- Desktop nav (hidden on mobile — MobileNav React island added in Phase 4) -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600 dark:text-gray-300">
      <a href="#services" class="hover:text-forest-green dark:hover:text-light-green transition-colors">Services</a>
      <a href="#about" class="hover:text-forest-green dark:hover:text-light-green transition-colors">About</a>
      <a href="#testimonials" class="hover:text-forest-green dark:hover:text-light-green transition-colors">Reviews</a>
      <a href="#contact" class="hover:text-forest-green dark:hover:text-light-green transition-colors">Contact</a>
    </nav>

    <!-- Click-to-call CTA — always visible on all breakpoints (CONV-02) -->
    <a
      href={NAP.phoneHref}
      class="inline-flex items-center gap-1.5 bg-redbird-red text-white px-4 py-2 rounded-full font-semibold text-sm hover:bg-[#a01830] hover:scale-[1.02] hover:shadow-md active:scale-100 transition-all duration-200"
      aria-label={`Call ${NAP.name} at ${NAP.phone}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.39 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
      <span class="hidden sm:inline">{NAP.phone}</span>
      <span class="sm:hidden">Call Now</span>
    </a>
  </div>
</header>
