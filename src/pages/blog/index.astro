---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const title = 'Lawn Care Blog | Redbird Lawn Care Service – Wentzville, MO';
const description = 'Practical lawn care tips from Alberto Murillo of Redbird Lawn Care in Wentzville, MO. Mowing, edging, watering, and more — written for Missouri homeowners.';
---

<Layout title={title} description={description}>
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="font-heading font-bold text-3xl md:text-4xl text-forest-green dark:text-light-green mb-3">
      Lawn Care Tips from Alberto
    </h1>
    <p class="text-gray-600 dark:text-gray-400 text-lg mb-12">
      Practical advice for Wentzville homeowners — written from the seat of a mower.
    </p>

    {posts.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">Articles coming soon. Check back shortly!</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-6 shadow-sm hover:shadow-md hover:border-forest-green dark:hover:border-light-green transition-all duration-200"
          >
            <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500 mb-3 font-medium uppercase tracking-wide">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              {post.data.tags && post.data.tags[0] && (
                <span class="text-redbird-red">· {post.data.tags[0]}</span>
              )}
            </div>
            <h2 class="font-heading font-semibold text-lg text-gray-900 dark:text-gray-100 group-hover:text-forest-green dark:group-hover:text-light-green transition-colors mb-2 leading-snug">
              {post.data.title}
            </h2>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-3">
              {post.data.excerpt}
            </p>
            <span class="inline-block mt-4 text-sm font-semibold text-forest-green dark:text-light-green group-hover:underline">
              Read more →
            </span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
