---
// src/pages/index.astro
// Complete single-page composition — all sections wired
// React islands (ContactForm, MobileNav, VAPIWidget) added in Phase 4
import Layout from '../layouts/Layout.astro';
import Header from '../components/astro/Header.astro';
import TrustBar from '../components/astro/TrustBar.astro';
import Hero from '../components/astro/Hero.astro';
import Services from '../components/astro/Services.astro';
import About from '../components/astro/About.astro';
import Testimonials from '../components/astro/Testimonials.astro';
import Footer from '../components/astro/Footer.astro';
import ContactForm from '../components/react/ContactForm';
import { buildFAQSchema, buildServiceSchema } from '../lib/schema';
import { getCollection } from 'astro:content';

const faqSchema = buildFAQSchema();
const serviceSchemas = buildServiceSchema();

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Layout
  title="Lawn Care Service in Wentzville, MO | Redbird Lawn Service"
  description="Redbird Lawn Service provides residential lawn care in Wentzville, MO — mowing, trimming, mulch & seasonal cleanups. No contracts. Free quote today."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    {serviceSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </Fragment>
  <Header />
  <TrustBar />
  <main id="main-content">
    <Hero />
    <Services />
    <About />
    <Testimonials />

    <section id="why-redbird" class="py-16 sm:py-20 px-4 bg-white dark:bg-dark-bg" aria-labelledby="why-heading">
      <div class="max-w-3xl mx-auto text-center">
        <h2 id="why-heading" class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-6" data-animate>
          Why Wentzville Homeowners Choose Redbird
        </h2>
        <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-8" data-animate>
          There's no shortage of lawn mowing companies in St. Charles County.
          Here's what makes Redbird Lawn Service different: we're local, we show up on time,
          and we treat every yard like it's our own — because we live right here in Wentzville.
        </p>
        <ul class="text-left space-y-3 text-gray-600 dark:text-gray-300 max-w-xl mx-auto" data-animate>
          <li class="flex items-start gap-3"><span class="text-redbird-red font-bold mt-0.5">✓</span> No contracts — cancel anytime with zero fees</li>
          <li class="flex items-start gap-3"><span class="text-redbird-red font-bold mt-0.5">✓</span> Fully insured for your peace of mind</li>
          <li class="flex items-start gap-3"><span class="text-redbird-red font-bold mt-0.5">✓</span> Professional-grade equipment on every visit</li>
          <li class="flex items-start gap-3"><span class="text-redbird-red font-bold mt-0.5">✓</span> Free estimates — no pressure, no surprise invoices</li>
          <li class="flex items-start gap-3"><span class="text-redbird-red font-bold mt-0.5">✓</span> Serving Wentzville, O'Fallon, Lake Saint Louis, Troy & Foristell</li>
        </ul>
      </div>
    </section>

    <!-- FAQ section — question-based headings for SEO and AI citability -->
    <section
      id="faq"
      class="py-16 sm:py-20 px-4 bg-gray-50 dark:bg-gray-900"
      aria-labelledby="faq-heading"
    >
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10" data-animate>
          <h2
            id="faq-heading"
            class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-4"
          >
            Common Questions
          </h2>
        </div>

        <div class="space-y-8">

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              How much does lawn mowing cost in Wentzville?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              Every yard is different. Lot size, grass type, and frequency all factor into the price.
              We provide free, no-obligation quotes so you know exactly what to expect before we ever
              show up. No surprises on your bill.
            </p>
          </div>

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              Do you require contracts?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              No. We believe in earning your business every week, not locking you in. Whether you need
              weekly service or a one-time cleanup, there is no contract and no cancellation fee.
            </p>
          </div>

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              What areas do you serve?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              We serve residential homes in Wentzville, O'Fallon, Lake Saint Louis, Troy, and Foristell.
              If you are in St. Charles County and are unsure whether we cover your neighborhood,
              give us a call and we will let you know right away.
            </p>
          </div>

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              Do I need to provide any equipment?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              No. We bring all professional-grade equipment to every job. Mowers, trimmers, edgers,
              blowers — everything is on our truck. All you need to do is let us know when to show up.
            </p>
          </div>

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              How much does sod installation cost in Wentzville?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              Cost depends on yard size, soil condition, and sod variety. Most residential sod jobs in
              the Wentzville area run between $1 to $2 per square foot installed, including soil prep
              and cleanup. We provide free on-site estimates so you know the exact price before any
              work begins.
            </p>
          </div>

          <div data-animate>
            <h3 class="font-heading font-semibold text-xl text-forest-green dark:text-light-green mb-2">
              How long does new sod take to establish?
            </h3>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
              In warm weather (May through August), new sod typically roots in 10 to 14 days. In
              cooler fall temperatures, it can take 3 to 4 weeks. We provide a post-install care
              guide with watering instructions to help your new lawn establish quickly.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Latest Lawn Care Tips blog preview -->
    <section id="blog-preview" class="py-16 sm:py-20 px-4 bg-white dark:bg-dark-bg" aria-labelledby="blog-preview-heading">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10" data-animate>
          <h2 id="blog-preview-heading" class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-4">
            Latest Lawn Care Tips
          </h2>
          <p class="text-gray-600 dark:text-gray-300 text-lg">
            Practical advice for Wentzville homeowners — written from the seat of a mower.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-3">
          {latestPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-6 shadow-sm hover:shadow-md hover:border-forest-green dark:hover:border-light-green transition-all duration-200"
              data-animate
            >
              <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500 mb-3 font-medium uppercase tracking-wide">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>
                {post.data.tags && post.data.tags[0] && (
                  <span class="text-redbird-red">· {post.data.tags[0]}</span>
                )}
              </div>
              <h3 class="font-heading font-semibold text-lg text-gray-900 dark:text-gray-100 group-hover:text-forest-green dark:group-hover:text-light-green transition-colors mb-2 leading-snug">
                {post.data.title}
              </h3>
              <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-3">
                {post.data.excerpt}
              </p>
              <span class="inline-block mt-4 text-sm font-semibold text-forest-green dark:text-light-green group-hover:underline">
                Read more →
              </span>
            </a>
          ))}
        </div>

        <div class="text-center mt-10" data-animate>
          <a
            href="/blog"
            class="inline-block text-sm font-semibold text-forest-green dark:text-light-green hover:underline"
          >
            View all tips →
          </a>
        </div>
      </div>
    </section>

    <!--
      Contact form section placeholder (id="contact" required by CTA href="#contact")
      Phase 4 React island (ContactForm) will replace this placeholder.
    -->
    <section
      id="contact"
      class="py-16 sm:py-20 px-4 bg-white dark:bg-dark-bg"
      aria-labelledby="contact-heading"
    >
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8" data-animate>
          <h2
            id="contact-heading"
            class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-4"
          >
            Get a Free Quote
          </h2>
          <p class="text-gray-600 dark:text-gray-300">
            Tell us about your lawn and we'll be in touch within 24 hours.
          </p>
        </div>
        <ContactForm client:idle />
      </div>
    </section>

  </main>
  <Footer />
</Layout>
