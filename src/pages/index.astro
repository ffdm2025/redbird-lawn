---
// src/pages/index.astro
// Complete single-page composition — all sections wired
// React islands (ContactForm, MobileNav, VAPIWidget) added in Phase 4
import Layout from '../layouts/Layout.astro';
import Header from '../components/astro/Header.astro';
import TrustBar from '../components/astro/TrustBar.astro';
import Hero from '../components/astro/Hero.astro';
import Services from '../components/astro/Services.astro';
import About from '../components/astro/About.astro';
import Testimonials from '../components/astro/Testimonials.astro';
import Footer from '../components/astro/Footer.astro';
---
<Layout title="Redbird Lawn Care Service | Top Rated Mowing in Wentzville, MO">
  <Header />
  <TrustBar />
  <main id="main-content">
    <Hero />
    <Services />
    <About />
    <Testimonials />

    <!--
      Contact form section placeholder (id="contact" required by CTA href="#contact")
      Phase 4 React island (ContactForm) will replace this placeholder.
    -->
    <section
      id="contact"
      class="py-16 sm:py-20 px-4 bg-white dark:bg-dark-bg"
      aria-labelledby="contact-heading"
    >
      <div class="max-w-xl mx-auto text-center" data-animate>
        <h2
          id="contact-heading"
          class="font-heading font-bold text-3xl sm:text-4xl text-forest-green dark:text-light-green mb-4"
        >
          Get a Free Quote
        </h2>
        <p class="text-gray-600 dark:text-gray-300 mb-2">
          Contact form coming soon — or call us now:
        </p>
        <a
          href="tel:+13144976152"
          class="inline-flex items-center gap-2 bg-redbird-red text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-[#a01830] hover:scale-[1.02] hover:shadow-lg transition-all duration-200 mt-4"
        >
          Call (314) 497-6152
        </a>
        <p class="text-gray-400 dark:text-gray-500 text-sm mt-4">We respond within 24 hours.</p>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
