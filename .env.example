# Phase 4 React Islands — required environment variables
# Copy to .env and fill in real values (never commit .env)

# GHL inbound webhook URL — from GHL > Automation > Workflow > Trigger > Copy Webhook URL
# If GHL CORS probe fails (see Plan 02), replace this with the Cloudflare Worker proxy URL instead
PUBLIC_GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME

# VAPI public key — from app.vapi.ai > Account > API Keys (public key, NOT private key)
PUBLIC_VAPI_KEY=REPLACE_ME

# VAPI assistant ID — from app.vapi.ai > Assistants > Vivian > Copy ID
PUBLIC_VAPI_ASSISTANT_ID=REPLACE_ME

# GHL API key — from GHL > Settings > Business Profile > API Key
# Required for pipeline management and future AI agent upgrade
GHL_API_KEY=REPLACE_ME

# Maria's phone number — receives lead notifications via SMS
# Format: +1XXXXXXXXXX (E.164)
MARIA_PHONE=REPLACE_ME

# Maria's email — receives lead notifications via email
MARIA_EMAIL=REPLACE_ME
